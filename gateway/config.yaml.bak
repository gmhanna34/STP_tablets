      label: MoIP Controller
      ip: 10.100.60.62
      outlet: 1
    x32_mixer:
      label: X32 Mixer
      ip: 10.100.60.62
      outlet: 2
security:
  allowed_ips:
  - 10.100.60.
  - 10.100.
  - 10.10.
  - 172.16.
  - 127.0.0.1
  - 47.150.
  settings_pin: ''
  secret_key: ''
  session_timeout_minutes: 480
  remote_auth:
    username: ''
    password: ''
camlytics:
  communion_url: https://cloud.camlytics.com/feed/report/814c480b4a6d221401093b5bb77aff30
  communion_buffer_default: 5
  occupancy_url_peak: https://cloud.camlytics.com/feed/report/4f82c3553002b39064ef61fc87cb8621
  occupancy_url_live: https://cloud.camlytics.com/feed/report/1acd7636230cc6af595f30ecef335519
  occupancy_buffer_default: 12.5
  enter_url: https://cloud.camlytics.com/feed/report/521d0d268ead8cfeef6950a8676c8976
  enter_buffer_default: 0
  peak_window_hours: 2
  poll_interval: 5
polling:
  moip: 10
  x32: 5
  obs: 3
  projectors: 30
healthdash:
  app:
    refresh_seconds: 5
    check_interval_seconds: 10
    request_timeout_seconds: 7
    client_id: Health Check
  tablet_names:
    main-church: Main Church Tablet
    chapel: Chapel Tablet
    social-hall: Social Hall Tablet
    av-room: A/V Room Tablet
    conf-room: Conference Room Tablet
    gym: Gym Tablet
    lobby: Lobby Tablet
    office: Office Tablet
    test: Test Device
    pc: PC
    admin: Admin
    Tablet_Mainchurch: Main Church Tablet
    Tablet_Chapel: Chapel Tablet
    Tablet_SocialHall: Social Hall Tablet
    Tablet_ConferenceRoom: Conference Room Tablet
    Tablet_Gym: Gym Tablet
    Tablet_Lobby: Lobby Tablet
    Tablet_Office: Office Tablet
  home_assistant:
    base_url: ''
    token: ''
    verify_tls: true
  alerts:
    ha_webhook_url: ''
    defaults:
      enabled: true
      warn_after_seconds: 30
      down_after_seconds: 60
      cooldown_seconds: 300
  security:
    trusted_ip_prefixes:
    - 10.100.60.
    - 10.100.
    - 10.10.
    - 172.16.
    - 127.0.0.1
    - 47.150.
  services:
  - id: x32_module
    name: X32 Audio (Built-in Module)
    group: Core
    type: http_json
    url: http://127.0.0.1:20858/api/x32/health
    ok_json_path: healthy
    ok_json_value: true
    detail_json_paths:
      Scene: cur_scene
      Scene Name: cur_scene_name
    warn_if_ms_gt: 5500
    poll_interval_seconds: 120
    timeout_seconds: 20
    log_path: ''
    alert:
      enabled: false
  - id: moip_module
    name: MoIP Video (Built-in Module)
    group: Core
    type: http_json
    url: http://127.0.0.1:20858/api/moip/health
    ok_json_path: healthy
    ok_json_value: true
    warn_if_ms_gt: 500
    timeout_seconds: 10
    log_path: ''
  - id: obs_module
    name: OBS Streaming (Built-in Module)
    group: Core
    type: http_json
    url: http://127.0.0.1:20858/api/obs/status
    ok_json_path: healthy
    ok_json_value: true
    timeout_seconds: 5
    log_path: ''
    alert:
      enabled: true
      warn_after_seconds: 180
      down_after_seconds: 360
      cooldown_seconds: 300
  - id: stp_gateway
    name: STP Gateway (Control Panel)
    group: Core
    type: http_json
    url: http://127.0.0.1:20858/api/health
    ok_json_path: healthy
    ok_json_value: true
    detail_json_paths:
      Version: version
      Mock Mode: mock_mode
    warn_if_ms_gt: 2000
    timeout_seconds: 5
    show_standalone: true
    alert:
      enabled: true
      warn_after_seconds: 60
      down_after_seconds: 120
      cooldown_seconds: 300
  - id: home_assistant
    name: Home Assistant (Automation Hub)
    group: Automation Hubs
    type: http
    url: ''
    timeout_seconds: 5
    ok_http_codes:
    - 200
    bearer_token: ''
  - id: insteon
    name: Insteon (Automation Hub)
