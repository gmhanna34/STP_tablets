  devices: ''
home_assistant:
  url: ''
  token: ''
  timeout: 10
wattbox:
  username: admin
  password: ''
  timeout: 5
  devices:
    ha_server:
      label: Home Assistant Server
      ip: 10.100.60.61
      outlet: 1
    livestream_pc:
      label: Live Stream PC
      ip: 10.100.60.61
      outlet: 2
