gateway:
  host: 0.0.0.0
  port: 20858
  debug: false
  static_dir: ../frontend
middleware: null
obs:
  ws_url: ws://127.0.0.1:4455
  ws_password: ''
  ping_seconds: 3.0
  snapshot_seconds: 6.0
  offline_after_seconds: 10.0
  ping_fails_to_offline: 3
  max_scenes: 10
moip:
  host_internal: 10.100.20.11
  port_internal: 23
  host_external: external.stpauloc.org
  port_external: 2323
  username: ''
  password: ''
  telnet_read_timeout: 5
  failure_threshold: 5
  reboot_cooldown_minutes: 15
  keepalive_interval_normal: 30
  keepalive_interval_max: 300
  ha_webhook_id: ''
x32:
  mixer_ip: 10.100.60.231
  mixer_type: X32
  ping_seconds: 2.0
  snapshot_seconds: 6.0
  offline_after_seconds: 8.0
  ping_fails_to_offline: 3
